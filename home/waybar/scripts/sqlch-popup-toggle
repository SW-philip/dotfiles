#!/usr/bin/env bash
# Toggle sqlch-popup: kill if running, launch if not.
PIDFILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/sqlch/popup.pid"

if [ -f "$PIDFILE" ]; then
    pid=$(cat "$PIDFILE")
    if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        rm -f "$PIDFILE"
        exit 0
    fi
    rm -f "$PIDFILE"
fi

mkdir -p "${PIDFILE%/*}"
sqlch-popup &
echo "$!" > "$PIDFILE"
