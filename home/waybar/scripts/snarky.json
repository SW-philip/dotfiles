#!/bin/bash

STATE_FILE="$HOME/.cache/weather_state"
[ -f "$STATE_FILE" ] || echo "temp" > "$STATE_FILE"
STATE=$(cat "$STATE_FILE")

API_KEY="YOUR_API_KEY"
CITY="Philadelphia"
UNITS="imperial"
SNARK_FILE="$HOME/.config/waybar/snark.json"

URL="https://api.openweathermap.org/data/2.5/weather?q=${CITY}&appid=${API_KEY}&units=${UNITS}"
WEATHER_JSON=$(curl -s "$URL")

if [[ -z "$WEATHER_JSON" ]]; then
  echo '{"text":"N/A","tooltip":"Weather API failed.","class":"unknown"}'
  exit 1
fi

TEMP=$(jq '.main.temp' <<< "$WEATHER_JSON")
HUMID=$(jq '.main.humidity' <<< "$WEATHER_JSON")
WIND=$(jq '.wind.speed' <<< "$WEATHER_JSON")
COND=$(jq -r '.weather[0].main' <<< "$WEATHER_JSON" | tr '[:upper:]' '[:lower:]')

TEMP=$(printf "%.0f" "$TEMP")
HUMID=$(printf "%.0f" "$HUMID")
WIND=$(printf "%.0f" "$WIND")

# Normalize condition
case "$COND" in
  *cloud*) CLASS="cloudy" ;;
  *rain*)  CLASS="rainy" ;;
  *sun*|*clear*) CLASS="sunny" ;;
  *) CLASS="unknown" ;;
esac

# Rotate output depending on STATE
case "$STATE" in
  temp)
    TEXT="${TEMP}°F"
    NEXT="wind"
    ;;
  wind)
    TEXT="💨 ${WIND} mph"
    NEXT="humid"
    ;;
  humid)
    TEXT="💧 ${HUMID}%"
    NEXT="condition"
    ;;
  condition)
    TEXT="☁️ ${COND}"
    NEXT="temp"
    ;;
esac

# Tooltip snark (same as before)
LEVEL="low"
if (( HUMID > 80 )); then LEVEL="high"
elif (( HUMID > 50 )); then LEVEL="medium"
fi

SNARK=$(jq -r --arg c "$CLASS" --arg l "$LEVEL" '
  .[$c][$l] | .[ (now | floor | tonumber) % length ]
' "$SNARK_FILE")

echo "{\"text\":\"$TEXT\",\"tooltip\":\"$SNARK\",\"class\":\"$CLASS\"}"

# Store next state for next click
echo "$NEXT" > "$STATE_FILE"
