{ config, pkgs, lib, ... }:
{
  imports = [
    ./cpu_temp.nix
    ./battery.nix
    ./clock.nix
    ./bluetooth.nix
    ./netstatus.nix
    ./volume.nix
    ./weather.nix
    ./mpris.nix
    ./wleave.nix
  ];

  waybar.cpu_temp.enable = true;
  waybar.battery.enable = true;
  waybar.quantumClock.enable = true;
  waybar.bluetooth.enable = true;
  waybar.netstatus.enable = true;
  waybar.volume.enable = true;
  waybar.mpris.enable = true;
  waybar.weather.enable = true;
  waybar.wleave.enable = true;
  waybar.wleave.label = "⏻";
  waybar.wleave.tooltip = "Power";

  programs.waybar = {
    enable = true;
    systemd.enable = true;
    style = ./style.css;

    settings = {
      # Left monitor — system/info bar
      leftBar = {
        layer = "top";
        position = "top";
        output = "DP-2";
        height = 45;
        modules-left = [
          "hyprland/workspaces"
          "custom/cpu_temp"
          "custom/battery"
        ];
        modules-center = [
          "custom/clock"
          "custom/weather"
        ];
        modules-right = [
          "custom/bluetooth"
          "custom/network"
          "tray"
          "custom/choose_mode"
          "custom/wleave"
        ];
        "custom/choose_mode" = {
          exec = "echo '{\"text\": \"󰔎\", \"tooltip\": \"Toggle theme\"}'";
          on-click = "${config.xdg.configHome}/waybar/scripts/choose_mode.sh";
          return-type = "json";
          interval = "once";
        };
      };

      # Right monitor — media bar, pinned to bottom
      rightBar = {
        layer = "top";
        position = "bottom";
        output = "DP-3";
        height = 45;
        modules-left = [];
        modules-center = [
          "custom/mpris"
        ];
        modules-right = [
          "custom/volume"
        ];
      };
    };
  };

  xdg.configFile."theme/palette.sh".source = ./palette.sh;
  xdg.configFile."waybar/scripts" = {
    source = ./scripts;
    recursive = true;
  };
}
