# Nix build artifacts
result
result-*

# VM disk images
*.qcow2

# Python bytecode
__pycache__/
*.pyc

# Theme wallpapers (stay on disk, not in git)
themes/**/wallpaper-*.png

# Generated / profiling outputs (no reason to track these)
boot_profile*
commentlist.txt
urface-kbd-monitor.service

# Private key material (belt-and-suspenders; sops handles actual secrets)
*.key
*.pem
id_rsa
id_ed25519
.env
.env.*
.direnv/

# Secrets — encrypted by sops but personal; forks provide their own
secrets/
secrets.yaml

# Personal SSH public keys
desktop_key.pub

# Pytest cache and other nested tool artifacts
**/.pytest_cache/
nixos/
