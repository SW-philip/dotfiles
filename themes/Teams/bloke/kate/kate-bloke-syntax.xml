<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language SYSTEM "language.dtd">
<language name="bloke" version="1.0" kateversion="5.0" section="Sources" extensions="" mimetype="" priority="0">
  <highlighting>
    <list name="keywords">
      <item>def</item><item>class</item><item>return</item><item>if</item><item>else</item>
      <item>for</item><item>while</item><item>import</item><item>from</item><item>pass</item>
      <item>True</item><item>False</item><item>None</item><item>and</item><item>or</item><item>not</item>
    </list>
    <contexts>
      <context name="Normal" attribute="Normal Text" lineEndContext="#stay">
        <Keyword attribute="Keyword" context="#stay" String="keywords" />
        <Float attribute="Float" context="#stay" />
        <Int attribute="Decimal" context="#stay" />
        <String attribute="String" context="#stay" />
        <DetectChar attribute="Comment" context="Comment" char="#" />
        <RegExpr attribute="Function" context="#stay" String="[a-zA-Z_][a-zA-Z0-9_]*(?=\()" />
      </context>
      <context name="Comment" attribute="Comment" lineEndContext="#pop">
        <IncludeRules context="##Alerts" />
      </context>
    </contexts>
    <itemDatas>
      <itemData name="Normal Text" defStyleNum="dsNormal" spellChecking="false" />
      <itemData name="Keyword" defStyleNum="dsKeyword" color="#d85b27" selColor="#5492cd" />
      <itemData name="Function" defStyleNum="dsFunction" color="#d22d38" selColor="#5492cd" />
      <itemData name="Decimal" defStyleNum="dsDecVal" color="#d96a11" selColor="#5492cd" />
      <itemData name="Float" defStyleNum="dsFloat" color="#d96a11" selColor="#5492cd" />
      <itemData name="String" defStyleNum="dsString" color="#f47b1f" selColor="#5492cd" />
      <itemData name="Comment" defStyleNum="dsComment" color="#749cc3" selColor="#5492cd" />
      <itemData name="Alert" defStyleNum="dsAlert" color="#f9863e" selColor="#5492cd" />
    </itemDatas>
  </highlighting>
  <general>
    <keywords weakDeliminator="" />
    <indentation mode="normal" />
  </general>
</language>
