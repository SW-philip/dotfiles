#!/usr/bin/env bash
#=====================================================================
# find-waybar-scripts.sh
#
# Search for any reference to a script located under
#   $HOME/.config/waybar/scripts/
# in both:
#   • Nix files (including flake.nix, *.nix, etc.)
#   • Waybar configuration files (JSON/YAML/TOML)
#
# Usage:
#   ./find-waybar-scripts.sh   # defaults to $HOME/nixos as the repo root
#   ./find-waybar-scripts.sh -r /path/to/your/repo
#
# Requirements: bash, grep, find, xargs (standard on any Linux/NixOS)
#=====================================================================

set -euo pipefail

# ---------- Defaults ----------
REPO_ROOT="${HOME}/nixos"          # where your Home‑Manager flakes live
WAYBAR_CFG="${HOME}/.config/waybar"

# ---------- Helper functions ----------
usage() {
  cat <<EOF
Usage: $(basename "$0") [-r REPO_ROOT]

Options:
  -r PATH   Path to the root of your Home‑Manager/Nix repository
            (default: $HOME/nixos)
  -h        Show this help message and exit
EOF
  exit 0
}

error() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

# ---------- Parse CLI options ----------
while getopts ":r:h" opt; do
  case $opt in
    r) REPO_ROOT="${OPTARG}" ;;
    h) usage ;;
    \?) error "Invalid option: -${OPTARG}" ;;
    :)  error "Option -${OPTARG} requires an argument." ;;
  esac
done
shift $((OPTIND-1))

# Validate directories
[[ -d "$REPO_ROOT" ]] || error "Repository root not found: $REPO_ROOT"
[[ -d "$WAYBAR_CFG" ]] || error "Waybar config directory not found: $WAYBAR_CFG"

# ---------- 1️⃣ Search Nix files ----------
echo "🔎 Searching Nix files ..."
# Look for any of the following patterns:
#   * home/waybar/scripts/
#   * scripts/*.sh (relative reference)
#   * scripts/*.py (just in case)
NIX_MATCHES=$(grep -Ern \
  -e 'home/waybar/scripts/' \
  -e 'scripts/[^[:space:]]*\.(sh|py)' \
  "$REPO_ROOT"/*.nix "$REPO_ROOT"/**/*.nix 2>/dev/null || true)

if [[ -n "$NIX_MATCHES" ]]; then
  printf '\n--- Nix file matches ---\n'
  printf '%s\n' "$NIX_MATCHES"
else
  echo "No script references found in Nix files."
fi

# ---------- 2️⃣ Search Waybar config files ----------
echo ""
echo "🔎 Searching Waybar config files (JSON/YAML/TOML) ..."
# Find all supported config files and grep inside them
CONFIG_MATCHES=$(find "$WAYBAR_CFG" -type f \
  $$ -name '*.json' -o -name '*.yaml' -o -name '*.yml' -o -name '*.toml' $$ -print0 |
  xargs -0 grep -En 'scripts/[^[:space:]]*\.(sh|py)' 2>/dev/null || true)

if [[ -n "$CONFIG_MATCHES" ]]; then
  printf '\n--- Waybar config matches ---\n'
  printf '%s\n' "$CONFIG_MATCHES"
else
  echo "No script references found in Waybar config files."
fi

# ---------- Summary ----------
echo ""
printf '--- Summary ---\n'
printf 'Repo root examined          : %s\n' "$REPO_ROOT"
printf 'Waybar config directory     : %s\n' "$WAYBAR_CFG"
printf 'Nix file matches            : %s\n' "$(echo "$NIX_MATCHES" | wc -l | tr -d ' ')"
printf 'Waybar config matches       : %s\n' "$(echo "$CONFIG_MATCHES" | wc -l | tr -d ' ')"
