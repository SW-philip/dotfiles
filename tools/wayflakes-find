#!/usr/bin/env bash
#
# find-waybar-flake-script-uses
# -----------------------------------------
# Scan ~/nixos/home/waybar for any flake that references
# something inside the "home/waybar/scripts" directory.
#
# Usage:   ./find-waybar-flake-script-uses [options]
#
# Options:
#   -d DIR   Directory to scan (default: "$HOME/nixos/home/waybar")
#   -h       Show this help message and exit
#
# The script prints:
#   • The flake file path
#   • The matching line(s) (with line numbers)
#   • A short summary of how many matches were found
#
# Requirements: bash, grep, find, sed (all part of a typical Linux distro)

set -euo pipefail

# ---------- Default arguments ----------
BASE_DIR="${HOME}/nixos/home/waybar"

# ---------- Helper functions ----------
usage() {
  grep '^#' "$0" | sed -n '2,13p' | sed 's/^# //'
  exit 0
}

error() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

# ---------- Parse CLI options ----------
while getopts ":d:h" opt; do
  case $opt in
    d) BASE_DIR="${OPTARG}" ;;
    h) usage ;;
    \?) error "Invalid option: -${OPTARG}" ;;
    :)  error "Option -${OPTARG} requires an argument." ;;
  esac
done
shift $((OPTIND-1))

# Validate the base directory
[[ -d "$BASE_DIR" ]] || error "Directory not found: $BASE_DIR"

# ---------- Core logic ----------
declare -i total_matches=0
declare -a flake_files=()

# 1️⃣ Find candidate flake files
while IFS= read -r -d '' file; do
  flake_files+=("$file")
done < <(
  # a) Explicit flake.nix files
  find "$BASE_DIR" -type f -name 'flake.nix' -print0
  # b) Any *.nix that contains a flake‑input declaration
  find "$BASE_DIR" -type f -name '*.nix' -exec grep -Il 'inputs\.' {} + -print0
)

# Remove duplicates (a file could match both a) and b))
mapfile -t flake_files < <(printf '%s\n' "${flake_files[@]}" | sort -u)

# 2️⃣ Scan each flake for script references
for flake in "${flake_files[@]}"; do
  # Grep for the path fragment. We allow three forms:
  #   - "/home/.../home/waybar/scripts/…"
  #   - "home/waybar/scripts/…"  (relative to $HOME)
  #   - "scripts/…"               (when the flake lives inside home/waybar)
  mapfile -t matches < <(
    grep -En \
      -e '/home/[^[:space:]]*/home/waybar/scripts/' \
      -e 'home/waybar/scripts/' \
      -e 'scripts/' \
      "$flake" || true
  )

  if (( ${#matches[@]} )); then
    printf '\n=== Flake: %s ===\n' "$flake"
    for line in "${matches[@]}"; do
      printf '%s\n' "$line"
    done
    (( total_matches += ${#matches[@]} ))
  fi
done

# ---------- Summary ----------
printf '\n--- Summary ---\n'
printf 'Scanned directory : %s\n' "$BASE_DIR"
printf 'Flake files examined: %s\n' "${#flake_files[@]}"
printf 'Total script references found: %s\n' "$total_matches"

if (( total_matches == 0 )); then
  printf 'No flake appears to use anything from home/waybar/scripts.\n'
fi
